# ════════════════════════════════════════════════════════════════════════════════
# Kong Enterprise 3.14 - Hybrid Deployment Environment Variables
# ════════════════════════════════════════════════════════════════════════════════
#
# IMPORTANT: This file contains sensitive information (passwords, license keys)
#            DO NOT commit this file to version control!
#            Add ".env" to your .gitignore file
#
# Usage:
#   1. Copy this file: cp .env.example .env
#   2. Edit values (replace placeholders with your actual data)
#   3. Run: podman-compose -f kong-enterprise-hybrid-compose.yml up -d
#   4. The .env file will be automatically loaded
#
# ════════════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════════════
# 1. PostgreSQL Configuration
# ════════════════════════════════════════════════════════════════════════════════

# PostgreSQL superuser username (default is usually 'postgres', we use 'kong')
POSTGRES_USER=kong

# PostgreSQL password - CHANGE THIS TO A STRONG PASSWORD!
# Example: MySecure$Pass123!
# Requirements: At least 12 characters, mix of uppercase, lowercase, numbers, symbols
POSTGRES_PASSWORD=kong_secure_password_123

# PostgreSQL database name (the Kong database)
POSTGRES_DB=kong

# PostgreSQL port (usually 5432)
# If you need to access from host: POSTGRES_PORT=5432
POSTGRES_PORT=5432


# ════════════════════════════════════════════════════════════════════════════════
# 2. Kong Enterprise License Key (REQUIRED!)
# ════════════════════════════════════════════════════════════════════════════════
#
# You MUST have a valid Kong Enterprise license to run this setup.
# The license should be a complete JSON object provided by Kong.
#
# To get a license:
#   1. Contact Kong Sales: support@konghq.com
#   2. Request trial or production license for Kong Gateway Enterprise
#   3. You'll receive a JSON file via email
#   4. Paste the entire JSON content here (between the quotes)
#
# ⚠️  SECURITY WARNING:
#    - This is your license key - keep it PRIVATE!
#    - Never commit this to version control
#    - Never share this file with others
#    - Store backups in a secure location
#
# Example format (this is NOT a real license, just the structure):
# KONG_LICENSE_DATA='{"license":{"payload":{"admin_api":true,"billing":true,...},"license_expiration_date":32503680000,"license_key":"your_license_key_here"},"signature":"your_signature_here","version":3}'
#

KONG_LICENSE_DATA='{"license":{"payload":{"admin_api":true,"billing":true,"bots":true,"degraphql":true,"dev_portal":true,"dev_portal_analytics":true,"dims":true,"event_hooks":true,"flush_db":true,"geoip":true,"grants":true,"hmac":true,"jq":true,"jwt":true,"key_auth_enc":true,"ldap":true,"mtls_metadata":true,"oauth2":true,"openid_connect":true,"pg_failover":true,"proxy_cache":true,"rate_limiting_advanced":true,"rbac":true,"request_size_limiting":true,"response_transformer_advanced":true,"route_by_header":true,"route_transformer_advanced":true,"service_mesh_usable":true,"session":true,"statsd":true,"vault":true,"vaults_credentials":true,"vaults_reference":true,"websocket_size_limit":true},"license_expiration_date":32503680000,"license_key":"license_key_here"},"signature":"signature_here","version":3}'


# ════════════════════════════════════════════════════════════════════════════════
# 3. Kong Control Plane - Admin Credentials
# ════════════════════════════════════════════════════════════════════════════════
#
# Default admin user and password for Kong Manager UI (web dashboard)
# Accessible at: http://localhost:8002
#
# ⚠️  WARNING: Change these defaults for production!
#
# Default username (usually leave as is)
KONG_ADMIN_USER=kong_admin

# Default password - CHANGE THIS!
# Access Kong Manager at: http://localhost:8002 with these credentials
KONG_ADMIN_PASSWORD=kong_admin


# ════════════════════════════════════════════════════════════════════════════════
# 4. Optional: Kong Control Plane - Database Superuser
# ════════════════════════════════════════════════════════════════════════════════
#
# If using a separate database server, you might need these
# For local Podman setup, usually not needed (we create kong user automatically)
#

# POSTGRES_SUPERUSER_PASSWORD=master_password_here


# ════════════════════════════════════════════════════════════════════════════════
# 5. Optional: Docker/Podman Configuration
# ════════════════════════════════════════════════════════════════════════════════
#
# These are usually set by the system, but you can override if needed
#

# COMPOSE_PROJECT_NAME=kong_enterprise
# COMPOSE_FILE=kong-enterprise-hybrid-compose.yml


# ════════════════════════════════════════════════════════════════════════════════
# QUICK REFERENCE - What Each Variable Does
# ════════════════════════════════════════════════════════════════════════════════
#
# POSTGRES_PASSWORD
#   ├─ Used by: PostgreSQL container during initialization
#   ├─ Used by: Kong Control Plane to connect to database
#   └─ Used by: Kong Data Plane to connect to database
#
# KONG_LICENSE_DATA
#   ├─ Used by: Kong Control Plane
#   └─ Used by: Kong Data Plane (same license for both)
#
# KONG_ADMIN_USER / KONG_ADMIN_PASSWORD
#   ├─ Used by: Kong Manager UI (web dashboard)
#   └─ Access at: http://localhost:8002
#
# ════════════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════════════
# SETUP STEPS
# ════════════════════════════════════════════════════════════════════════════════
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env with your actual values:
#    - Strong PostgreSQL password
#    - Valid Kong Enterprise license
#    - New admin credentials (optional but recommended)
#
# 3. Add to .gitignore (IMPORTANT!):
#    echo ".env" >> .gitignore
#
# 4. Start the deployment:
#    podman-compose -f kong-enterprise-hybrid-compose.yml up -d
#
# 5. Wait for services to be healthy (30-60 seconds):
#    podman-compose -f kong-enterprise-hybrid-compose.yml ps
#
# 6. Access Kong Manager:
#    Open browser: http://localhost:8002
#    Login with: KONG_ADMIN_USER and KONG_ADMIN_PASSWORD
#
# ════════════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════════════
# VERIFICATION COMMANDS
# ════════════════════════════════════════════════════════════════════════════════
#
# Check if services are running:
#   podman-compose ps
#
# Check Control Plane health:
#   curl -s http://localhost:8001/status | jq .
#
# Check Data Plane health:
#   curl -s http://localhost:8000/status | jq .
#
# View logs:
#   podman logs -f kong-control-plane
#   podman logs -f kong-gateway
#   podman logs -f kong-postgres
#
# Connect to database directly:
#   podman exec -it kong-postgres psql -U kong -d kong
#
# ════════════════════════════════════════════════════════════════════════════════


# ════════════════════════════════════════════════════════════════════════════════
# SECURITY CHECKLIST
# ════════════════════════════════════════════════════════════════════════════════
#
# Before deploying to production, verify:
#
# [ ] .env file is in .gitignore
# [ ] POSTGRES_PASSWORD is strong (12+ chars, mix of types)
# [ ] KONG_LICENSE_DATA contains valid enterprise license
# [ ] KONG_ADMIN_PASSWORD has been changed from default
# [ ] License key is not shared with anyone
# [ ] .env file has restricted permissions: chmod 600 .env
# [ ] Backup your license key file
# [ ] Verify all passwords are different from each other
# [ ] Have a secure storage for license (encrypted vault, password manager)
#
# ════════════════════════════════════════════════════════════════════════════════

